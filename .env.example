# Admin Panel Environment Variables
# Copy this to .env and fill in your values

# Database (same as main app)
DB_USER=postgres
DB_HOST=localhost
DB_NAME=nisbat_connect
DB_PASSWORD=your_password_here
DB_PORT=5433

# JWT Secret for admin tokens (use a different secret than main app)
ADMIN_JWT_SECRET=your_super_secret_admin_key_here

# Server port
PORT=3003

# Main app URL (for CORS)
MAIN_APP_URL=http://localhost:5173
